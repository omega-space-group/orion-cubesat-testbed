		{"TaskA_Handler" , 3,{TOPIC_SYSTEM_STATE,TOPIC_EXAMPLE1,TOPIC_EXAMPLE2}},
		{"TaskB_Handler" , 2,{TOPIC_SYSTEM_STATE,TOPIC_EXAMPLE1}}
